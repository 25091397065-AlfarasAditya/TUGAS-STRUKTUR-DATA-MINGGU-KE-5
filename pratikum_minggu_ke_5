# SOAL 3 — Hybrid Sort (Versi Alternatif)
# ============================================================

import random

def insertion_v2(data):

    arr = data[:]
    comp = 0
    swap = 0

    for i in range(1,len(arr)):

        temp = arr[i]
        j = i-1

        while j >= 0 and arr[j] > temp:
            comp += 1
            arr[j+1] = arr[j]
            swap += 1
            j -= 1

        arr[j+1] = temp

    return arr, comp, swap


def selection_v2(data):

    arr = data[:]
    comp = 0
    swap = 0

    for i in range(len(arr)-1):

        idx = i

        for j in range(i+1,len(arr)):
            comp += 1

            if arr[j] < arr[idx]:
                idx = j

        if idx != i:
            arr[i], arr[idx] = arr[idx], arr[i]
            swap += 1

    return arr, comp, swap


def hybrid_sort(data, limit=10):

    if len(data) <= limit:
        return insertion_v2(data)
    else:
        return selection_v2(data)


sizes = [50,100,500]

print("Size  Algorithm      Comparisons  Swaps")

for s in sizes:

    random.seed(42)
    arr = [random.randint(1,1000) for _ in range(s)]

    for name, func in [
        ("Hybrid", hybrid_sort),
        ("Insertion", insertion_v2),
        ("Selection", selection_v2)
    ]:

        _,c,sw = func(arr)

        print(s, name, c, sw)

