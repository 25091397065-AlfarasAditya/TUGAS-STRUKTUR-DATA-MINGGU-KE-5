# SOAL 1 — Modified Binary Search (Versi Alternatif)
# ============================================================

def left_index(arr, key):
    start = 0
    end = len(arr) - 1
    pos = -1

    while start <= end:
        mid = (start + end) // 2

        if arr[mid] >= key:
            end = mid - 1
        else:
            start = mid + 1

        if arr[mid] == key:
            pos = mid

    return pos


def right_index(arr, key):
    start = 0
    end = len(arr) - 1
    pos = -1

    while start <= end:
        mid = (start + end) // 2

        if arr[mid] <= key:
            start = mid + 1
        else:
            end = mid - 1

        if arr[mid] == key:
            pos = mid

    return pos


def count_occurrences(arr, key):
    left = left_index(arr, key)
    right = right_index(arr, key)

    if left == -1:
        return 0

    return right - left + 1

