# SOAL 4 — Merge 3 Sorted Lists (Versi Alternatif)
# ============================================================

def merge_three(a,b,c):

    result = []

    i=j=k=0

    while i < len(a) or j < len(b) or k < len(c):

        va = a[i] if i < len(a) else float("inf")
        vb = b[j] if j < len(b) else float("inf")
        vc = c[k] if k < len(c) else float("inf")

        smallest = min(va,vb,vc)

        result.append(smallest)

        if smallest == va:
            i+=1
        elif smallest == vb:
            j+=1
        else:
            k+=1

    return result


