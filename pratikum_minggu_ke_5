# SOAL 2 — Bubble Sort (Versi Alternatif)
# ============================================================

def bubble_sort_analysis(lst):

    arr = lst[:]
    n = len(arr)

    comparisons = 0
    swaps = 0
    passes = 0

    for i in range(n):

        changed = False

        for j in range(0, n-i-1):

            comparisons += 1

            if arr[j] > arr[j+1]:
                arr[j], arr[j+1] = arr[j+1], arr[j]
                swaps += 1
                changed = True

        passes += 1
        print("Pass", passes, ":", arr)

        if not changed:
            print("Early stop pada pass", passes)
            break

    return arr, comparisons, swaps, passes


def test_bubble(arr):

    print("Input :", arr)

    result = bubble_sort_analysis(arr)

    print("Output:", result[0])
    print("Comparisons:", result[1])
    print("Swaps:", result[2])
    print("Passes:", result[3])


test_bubble([5,1,4,2,8])
test_bubble([1,2,3,4,5])
